---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import RegionCard from '../components/RegionCard.astro';
import Checklist from '../components/Checklist.astro';
import CtaBand from '../components/CtaBand.astro';
import { images } from '../assets/images';
import { regions } from '../data/regions';
import { fishingGear } from '../data/content';
---
<BaseLayout
  title="Fishing Regions | Emirates Fishing Tour"
  description="The best fishing regions in the UAE — Dubai Marina, the Persian Gulf, Palm Jumeirah and Musandam."
  active="regions"
>
  <Hero
    image={images['yacht-fishing']}
    alt="Yacht fishing off the Dubai coast"
    breadcrumb="Fishing regions"
    title="Fishing Regions in the UAE"
    subtitle="Know the right places, the right season and the right gear — we do."
  />

  <Section>
    <SectionHeading eyebrow="Yacht fishing" title="Where to fish around Dubai" />
    <p class="copy" style="max-width:820px">Fishing in the UAE should be approached thoroughly. After all, you need to know the right places for good fishing, and be consulted in advance about equipment and other technical issues. Our team of professionals will be happy to inform you and familiarize you with the details of the tour.</p>
    <p class="copy" style="max-width:820px">We know the best fishing spots and can provide you with a unique experience of fishing. From calm inshore waters along the Marina to deep-sea trolling in the Persian Gulf and the dramatic fjords of Musandam, every region has its own character, season and catch. Enjoy a great catch in the best fishing spots of Dubai!</p>
  </Section>

  <Section tint>
    <SectionHeading
      eyebrow="Fishing regions"
      title="Four waters worth casting a line in"
      lead="Choose the spot that fits your day — a relaxed family outing close to shore, a full-day big-game charter, or an extended cruise to untouched reefs."
    />
    <div class="grid grid--2" style="gap:28px">{regions.map((r) => <RegionCard region={r} />)}</div>
  </Section>

  <Section>
    <SectionHeading
      eyebrow="On every fishing charter"
      title="Everything you need on board"
      lead="Step aboard and fish — every charter comes complete. Here is what is ready and waiting before you cast your first line."
    />
    <Checklist items={fishingGear} cols={3} gap="26px 40px" />
  </Section>

  <CtaBand
    title="Book your fishing charter with Emirates Fishing Tour today"
    text="It is easy to rent a yacht in Dubai — just contact our specialists. We help you choose the right region, the right season and the right gear, plan your route and arrange every detail. Our team works 24/7."
  />
</BaseLayout>

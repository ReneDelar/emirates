---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Benefits from '../components/Benefits.astro';
import YachtCard from '../components/YachtCard.astro';
import ServiceTile from '../components/ServiceTile.astro';
import Checklist from '../components/Checklist.astro';
import FeatureSplit from '../components/FeatureSplit.astro';
import CtaBand from '../components/CtaBand.astro';
import { images } from '../assets/images';
import { fleet } from '../data/fleet';
import { services } from '../data/services';
import { advantagesHome } from '../data/content';
---
<BaseLayout
  title="Yacht Rental Dubai | Emirates Fishing Tour"
  description="Luxury yacht rental, fishing trips and cruises in Dubai. Fully insured, licensed crew, 24/7 booking."
  active="home"
>
  <Hero
    image={images['luxury-yacht-on-turquoise-water']}
    alt="Luxury yacht cruising on turquoise water in Dubai"
    eyebrow="Yacht Rental Dubai · 24/7 booking"
    title="Luxury Yacht Rental in Dubai"
    subtitle="Dubai is a paradise where every idea turns into reality — offering the very best conditions for water recreation. Whatever you dream of on the water, Emirates Fishing Tour helps you bring every idea to life."
    minHeight={560}
    titleSize={60}
    padY={64}
  >
    <div class="hero-actions">
      <a href="/yacht-rental" class="btn-light">View the fleet →</a>
      <a href="/contacts" class="btn-ghost">Contact us</a>
    </div>
  </Hero>

  <Section tint size="sm"><Benefits /></Section>

  <Section>
    <SectionHeading
      eyebrow="Our fleet"
      title="Most popular yachts in Dubai"
      lead="Our extensive fleet offers a wide range of yachts equipped with the latest features and amenities — all models meeting the highest technical and safety standards. Choose your favourite below."
    />
    <div class="grid grid--3">{fleet.map((y) => <YachtCard yacht={y} />)}</div>
    <div class="center mt-40"><a href="/yacht-rental" class="textlink">View all yachts →</a></div>
  </Section>

  <FeatureSplit
    image={images['dubai-coastline']}
    alt="Dubai coastline skyline from the water"
    eyebrow="Welcome to Dubai"
    title="A paradise where every idea turns into reality"
    tint
    mediaFirst
    mediaHeight={460}
    cols="1fr 1fr"
  >
    <p class="copy">Dubai is a city of great opportunities — one of the few places offering the very best conditions for water recreation. For fans of fishing, water sports, private celebrations, corporate events or simply lovers of luxurious recreation surrounded by mesmerizing landscapes, Emirates Fishing Tour helps you bring every idea to life.</p>
    <p class="copy">From renting a modern yacht for a charter in the Persian Gulf to a group theme cruise, our team of experts does everything possible to give you an exceptional yacht charter holiday in Dubai, complete with stunning views and ideal onboard amenities.</p>
    <a href="/about" class="btn" style="margin-top:10px">About us</a>
  </FeatureSplit>

  <Section>
    <SectionHeading
      eyebrow="Our services"
      title="Many formats of water recreation"
      lead="From sightseeing cruises to corporate celebrations — choose the experience that fits your day on the water."
    />
    <div class="grid grid--3">{services.map((s) => <ServiceTile service={s} />)}</div>
  </Section>

  <Section tint>
    <SectionHeading eyebrow="Our advantages" title="Why guests choose Emirates Fishing Tour" />
    <Checklist items={advantagesHome} cols={2} gap="16px 40px" />
  </Section>

  <CtaBand />
</BaseLayout>

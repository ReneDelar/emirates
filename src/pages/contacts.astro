---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactForm from '../components/ContactForm.astro';
import Pills from '../components/Pills.astro';
import { images } from '../assets/images';
import { landmarks } from '../data/content';

const chip = 'shrink-0 w-[52px] h-[52px] rounded-[14px] bg-chip flex items-center justify-center';
const crow = 'flex items-center gap-[14px] no-underline';
---
<BaseLayout
  title="Contacts | Emirates Fishing Tour"
  description="Contact Emirates Fishing Tour to book your yacht in Dubai. We work 24/7."
  active="contacts"
>
  <Hero
    image={images['turquoise-sea']}
    alt="Turquoise sea off the Dubai coast"
    breadcrumb="Contacts"
    title="Contact Us"
    subtitle="Book your yacht — we work 24/7."
    minHeight={380}
  />

  <section class="section" data-reveal>
    <div class="container grid grid-cols-[.92fr_1.08fr] gap-[60px] items-start max-[980px]:grid-cols-1" data-reveal-root>
      <div>
        <p class="eyebrow">Get in touch</p>
        <h2 class="section-title">Book your yacht — we work 24/7</h2>
        <p class="copy">It is easy to rent a yacht in Dubai — just contact our specialists and managers. You can find out about availability, possible directions and routes, current promotions and prices, and we will be happy to select or create the perfect route so you can enjoy your vacation.</p>
        <p class="copy">When it comes to water recreation, safety plays a big role. By renting a boat or yacht from us, you automatically receive a guarantee of safety — you will be <strong class="text-navy">fully insured</strong>. We take into account every nuance: whether there are children on board, fishing enthusiasts, or fans of jet skiing, banana boating and flyboarding. Our goal is to make your vacation as comfortable as possible.</p>

        <div class="flex flex-col gap-[22px] mt-2">
          <a href="tel:+971000000000" class={crow}>
            <span class={chip}><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1869B3" stroke-width="1.7"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg></span>
            <span><span class="block font-extrabold text-[17px] text-navy-ink">Call us anytime</span><span class="block text-[14px] text-soft">+971 00 000 0000</span></span>
          </a>
          <a href="https://wa.me/971000000000" class={crow}>
            <span class={chip}><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1869B3" stroke-width="1.7"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"></path></svg></span>
            <span><span class="block font-extrabold text-[17px] text-navy-ink">WhatsApp</span><span class="block text-[14px] text-soft">+971 00 000 0000</span></span>
          </a>
          <a href="mailto:info@emiratesfishingtour.com" class={crow}>
            <span class={chip}><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1869B3" stroke-width="1.7"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"></path><path d="M22 6l-10 7L2 6"></path></svg></span>
            <span><span class="block font-extrabold text-[17px] text-navy-ink">Email & website</span><span class="block text-[14px] text-soft">info@emiratesfishingtour.com</span></span>
          </a>
        </div>

        <div class="mt-[30px] pt-6 border-t border-line">
          <div class="font-bold text-[14px] text-head mb-1">Working hours</div>
          <div class="text-[15px] text-mute">Open 24/7, every day of the year.</div>
        </div>
      </div>

      <ContactForm />
    </div>
  </section>

  <Section tint>
    <SectionHeading
      eyebrow="Routes & locations"
      title="Where you'll cruise"
      lead="From the marina to the open Gulf, your route can take in the most iconic landmarks of Dubai. Tell us where you'd like to sail and we'll plan every detail around you."
    />
    <Pills items={landmarks} />
  </Section>
</BaseLayout>

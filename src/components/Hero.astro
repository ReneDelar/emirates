---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  title: string;
  breadcrumb?: string;
  eyebrow?: string;
  subtitle?: string;
  minHeight?: number;
  titleSize?: number;
  padY?: number;
}
const { image, alt, title, breadcrumb, eyebrow, subtitle, minHeight = 430, titleSize = 56, padY = 0 } = Astro.props;
const titleMax = titleSize >= 60 ? 800 : 760;
---
<section class="relative flex items-center overflow-hidden" data-reveal data-hero style={`min-height:${minHeight}px`}>
  <Image src={image} alt={alt} class="absolute inset-0 w-full h-full object-cover" widths={[768, 1280, 1920]} sizes="100vw" />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(9,33,53,.64)_0%,rgba(9,33,53,.32)_46%,rgba(9,33,53,.05)_80%)]"></div>
  <div class="container relative w-full" data-reveal-root style={padY ? `padding-top:${padY}px;padding-bottom:${padY}px` : undefined}>
    {breadcrumb && (
      <div class="flex items-center gap-[9px] font-semibold text-[13.5px] text-[#dce8f2] mb-[22px]">
        <a href="/" class="text-white no-underline">Home</a><span class="opacity-[.55]">/</span><span class="opacity-90">{breadcrumb}</span>
      </div>
    )}
    {eyebrow && <p class="eyebrow eyebrow-light">{eyebrow}</p>}
    <h1
      class="font-extrabold leading-[1.05] tracking-[-.015em] text-white [text-shadow:0_2px_18px_rgba(6,24,40,.35)] max-sm:!text-[36px]"
      style={`font-size:${titleSize}px;max-width:${titleMax}px`}
    >{title}</h1>
    {subtitle && <p class="text-[18px] leading-[1.6] text-[#e8f1f8] mt-[18px] max-w-[620px] [text-shadow:0_1px_10px_rgba(6,24,40,.3)]">{subtitle}</p>}
    <slot />
  </div>
</section>

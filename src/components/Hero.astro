---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  title: string;
  breadcrumb?: string;
  eyebrow?: string;
  subtitle?: string;
  minHeight?: number;
  titleSize?: number;
  padY?: number;
}
const { image, alt, title, breadcrumb, eyebrow, subtitle, minHeight = 430, titleSize = 56, padY = 0 } = Astro.props;
const titleMax = titleSize >= 60 ? 800 : 760;
---
<section class="hero" data-reveal style={`min-height:${minHeight}px`}>
  <Image src={image} alt={alt} class="hero__bg" widths={[768, 1280, 1920]} sizes="100vw" />
  <div class="hero__overlay"></div>
  <div class="container hero__inner" style={padY ? `padding-top:${padY}px;padding-bottom:${padY}px` : undefined}>
    {breadcrumb && (
      <div class="hero__crumb">
        <a href="/">Home</a><span class="sep">/</span><span class="cur">{breadcrumb}</span>
      </div>
    )}
    {eyebrow && <p class="eyebrow eyebrow--light">{eyebrow}</p>}
    <h1 class="hero__title" style={`font-size:${titleSize}px;max-width:${titleMax}px`}>{title}</h1>
    {subtitle && <p class="hero__sub">{subtitle}</p>}
    <slot />
  </div>
</section>

<style>
  .hero { position: relative; display: flex; align-items: center; overflow: hidden; }
  .hero__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hero__overlay { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(9,33,53,.64) 0%, rgba(9,33,53,.32) 46%, rgba(9,33,53,.05) 80%); }
  .hero__inner { position: relative; width: 100%; }
  .hero__crumb { display: flex; align-items: center; gap: 9px; font-weight: 600; font-size: 13.5px; color: #dce8f2; margin-bottom: 22px; }
  .hero__crumb a { color: #fff; text-decoration: none; }
  .hero__crumb .sep { opacity: .55; }
  .hero__crumb .cur { opacity: .9; }
  .hero__title { font-weight: 800; line-height: 1.05; letter-spacing: -.015em; color: #fff; text-shadow: 0 2px 18px rgba(6,24,40,.35); }
  .hero__sub { font-size: 18px; line-height: 1.6; color: #e8f1f8; margin-top: 18px; max-width: 620px; text-shadow: 0 1px 10px rgba(6,24,40,.3); }
  .hero :global(.hero-actions) { display: flex; flex-wrap: wrap; align-items: center; gap: 16px; margin-top: 34px; }
</style>

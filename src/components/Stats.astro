---
interface Props { items: { value: string; label: string }[] }
const { items } = Astro.props;
---
<section class="bg-navy py-14 px-7" data-reveal>
  <div class="container grid grid-cols-4 gap-6 max-[980px]:grid-cols-2 max-[640px]:grid-cols-1" data-reveal-root>
    {items.map((s) => (
      <div class="text-center">
        <div class="font-extrabold text-[40px] text-white leading-none">{s.value}</div>
        <div class="text-[14px] text-[#9fb4c6] mt-2">{s.label}</div>
      </div>
    ))}
  </div>
</section>

---
interface Props {
  tint?: boolean;
  size?: 'sm' | 'md' | 'lg';
  id?: string;
  reveal?: boolean;
  scrollAnchor?: boolean;
}
const { tint = false, size = 'md', id, reveal = true, scrollAnchor = false } = Astro.props;
const sizeCls = size === 'sm' ? 'section-sm' : size === 'lg' ? 'section-lg' : 'section';
const cls = [sizeCls, tint && 'bg-tint', scrollAnchor && 'scroll-mt-[90px]'].filter(Boolean).join(' ');
---
<section class={cls} id={id} data-reveal={reveal ? '' : undefined}>
  <div class="container" data-reveal-root><slot /></div>
</section>

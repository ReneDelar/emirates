---
import { Image } from 'astro:assets';
import type { Service } from '../data/services';
interface Props { service: Service }
const { service } = Astro.props;
---
<a href={`/excursions#${service.id}`} class="card group block rounded-[12px] no-underline">
  <div class="h-[208px] overflow-hidden">
    <Image src={service.image} alt={service.alt} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
  </div>
  <div class="pt-5 px-[22px] pb-6">
    <p class="font-bold text-[12px] tracking-[.14em] uppercase text-brand mb-2">{service.category}</p>
    <h3 class="font-bold text-[20px] text-head mb-2">{service.title}</h3>
    <p class="text-[14.5px] leading-[1.7] text-mute">{service.short}</p>
  </div>
</a>

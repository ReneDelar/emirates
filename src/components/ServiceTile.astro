---
import { Image } from 'astro:assets';
import type { Service } from '../data/services';
interface Props { service: Service }
const { service } = Astro.props;
---
<a href={`/excursions#${service.id}`} class="card svc-tile tile">
  <div class="tile__media"><Image src={service.image} alt={service.alt} class="tile__img" /></div>
  <div class="tile__body">
    <p class="tile__cat">{service.category}</p>
    <h3 class="tile__title">{service.title}</h3>
    <p class="tile__txt">{service.short}</p>
  </div>
</a>

<style>
  .tile { display: block; border-radius: 12px; text-decoration: none; }
  .tile__media { height: 208px; overflow: hidden; }
  .tile__img { width: 100%; height: 100%; object-fit: cover; }
  .tile__body { padding: 20px 22px 24px; }
  .tile__cat { font-weight: 700; font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--brand); margin: 0 0 8px; }
  .tile__title { font-weight: 700; font-size: 20px; color: var(--head); margin: 0 0 8px; }
  .tile__txt { font-size: 14.5px; line-height: 1.7; color: var(--text-mute); margin: 0; }
</style>

---
import { Image } from 'astro:assets';
import { images } from '../assets/images';
interface Props { eyebrow?: string; title?: string; text?: string; cta?: string }
const {
  eyebrow = 'Rent yachts in Dubai',
  title = 'Book your yacht with Emirates Fishing Tour today',
  text = 'It is easy to rent a yacht in Dubai — just contact our specialists. We help you choose and book any yacht, plan your route and arrange every detail. Our team works 24/7.',
  cta = 'Book a yacht now →',
} = Astro.props;
---
<section class="cta" data-reveal>
  <Image src={images['turquoise-sea']} alt="Turquoise sea" class="cta__bg" widths={[768, 1280, 1920]} sizes="100vw" />
  <div class="cta__overlay"></div>
  <div class="cta__inner">
    <p class="cta__eyebrow">{eyebrow}</p>
    <h2 class="cta__title">{title}</h2>
    <p class="cta__text">{text}</p>
    <a class="btn-light" href="/contacts">{cta}</a>
  </div>
</section>

<style>
  .cta { position: relative; padding: 92px var(--pad-x); overflow: hidden; }
  .cta__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .cta__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(24,105,179,.86), rgba(18,80,140,.9)); }
  .cta__inner { position: relative; max-width: 900px; margin: 0 auto; text-align: center; color: #fff; }
  .cta__eyebrow { font-weight: 700; font-size: 13px; letter-spacing: .18em; text-transform: uppercase; color: #cfe6f7; margin: 0 0 14px; }
  .cta__title { font-weight: 800; font-size: 42px; line-height: 1.1; letter-spacing: -.015em; margin: 0 0 18px; }
  .cta__text { font-size: 17px; line-height: 1.7; color: #e7f1fa; margin: 0 auto 28px; max-width: 680px; }
  @media (max-width: 640px) { .cta__title { font-size: 28px; } }
</style>

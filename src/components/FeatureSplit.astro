---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
interface Props {
  image: ImageMetadata;
  alt: string;
  eyebrow: string;
  title: string;
  tint?: boolean;
  mediaFirst?: boolean;
  mediaHeight?: number;
  sticky?: boolean;
  align?: 'center' | 'start';
  cols?: string;
}
const { image, alt, eyebrow, title, tint = false, mediaFirst = false, mediaHeight = 440, sticky = false, align = 'center', cols } = Astro.props;
const gridStyle = `align-items:${align};${cols ? `grid-template-columns:${cols};` : ''}`;
---
<section class={`section fs${tint ? ' section--tint' : ''}`} data-reveal>
  <div class="container fs__grid" style={gridStyle}>
    <div class={`media fs__media${mediaFirst ? ' fs__media--first' : ''}${sticky ? ' fs__media--sticky' : ''}`} style={`height:${mediaHeight}px`}>
      <Image src={image} alt={alt} />
    </div>
    <div class="fs__body">
      <p class="eyebrow">{eyebrow}</p>
      <h2 class="section-title fs__title">{title}</h2>
      <slot />
    </div>
  </div>
</section>

<style>
  .fs__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; }
  .fs__media { box-shadow: 0 14px 36px rgba(20,50,75,.14); }
  .fs__media--first { order: -1; }
  .fs__media--sticky { position: sticky; top: 28px; }
  .fs__title { margin-bottom: 18px; }
  @media (max-width: 980px) {
    .fs__grid { grid-template-columns: 1fr !important; }
    .fs__media--sticky { position: static; }
    .fs__media--first { order: -1; }
  }
</style>

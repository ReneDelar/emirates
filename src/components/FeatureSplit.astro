---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
interface Props {
  image: ImageMetadata;
  alt: string;
  eyebrow: string;
  title: string;
  tint?: boolean;
  mediaFirst?: boolean;
  mediaHeight?: number;
  sticky?: boolean;
  align?: 'center' | 'start';
  cols?: string;
}
const { image, alt, eyebrow, title, tint = false, mediaFirst = false, mediaHeight = 440, sticky = false, align = 'center', cols } = Astro.props;
const gridStyle = `align-items:${align};` + (cols ? `grid-template-columns:${cols};` : '');
const mediaCls = [
  'rounded-[14px] overflow-hidden shadow-[0_14px_36px_rgba(20,50,75,.14)]',
  mediaFirst && 'order-[-1]',
  sticky && 'sticky top-7 max-[980px]:static',
].filter(Boolean).join(' ');
---
<section class={`section${tint ? ' bg-tint' : ''}`} data-reveal>
  <div class="container grid grid-cols-2 gap-[50px] max-[980px]:!grid-cols-1" data-reveal-root style={gridStyle}>
    <div class={mediaCls} style={`height:${mediaHeight}px`}>
      <Image src={image} alt={alt} class="w-full h-full object-cover" />
    </div>
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h2 class="section-title mb-[18px]">{title}</h2>
      <slot />
    </div>
  </div>
</section>

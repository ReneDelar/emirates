---
interface Props {
  items: string[];
  cols?: number;
  gap?: string;
}
const { items, cols = 3, gap = '26px 40px' } = Astro.props;
const gridCols = cols === 2
  ? 'grid-cols-2 max-[640px]:grid-cols-1'
  : 'grid-cols-3 max-[980px]:grid-cols-2 max-[640px]:grid-cols-1';
---
<div class={`grid ${gridCols}`} style={`gap:${gap}`} data-grid>
  {items.map((t) => (
    <div class="flex items-start gap-[12px]">
      <span class="shrink-0 w-[26px] h-[26px] rounded-full bg-chip flex items-center justify-center mt-px">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1869B3" stroke-width="2.4"><path d="M20 6L9 17l-5-5"></path></svg>
      </span>
      <span class="text-[15.5px] text-ink leading-[1.5]">{t}</span>
    </div>
  ))}
</div>

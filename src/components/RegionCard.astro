---
import { Image } from 'astro:assets';
import type { Region } from '../data/regions';
interface Props { region: Region }
const { region } = Astro.props;
---
<article class="card rounded-[12px] scroll-mt-[90px]" id={region.id}>
  <div class="h-[230px] overflow-hidden">
    <Image src={region.image} alt={region.alt} class="w-full h-full object-cover" />
  </div>
  <div class="pt-6 px-[26px] pb-[26px]">
    <h3 class="font-bold text-[22px] text-head mb-[10px]">{region.title}</h3>
    <p class="text-[15.5px] leading-[1.7] text-mute mb-[18px]">{region.text}</p>
    <a href="/contacts" class="textlink !text-[14.5px]">Plan a trip &rarr;</a>
  </div>
</article>

---
import { Image } from 'astro:assets';
import logoBlue from '../assets/logo-blue.png';
export type NavKey = 'home' | 'about' | 'regions' | 'yachts' | 'excursions' | 'contacts';
interface Props { active?: NavKey }
const { active } = Astro.props;

interface Item { key: NavKey; label: string; href: string; dropdown?: { label: string; href: string }[] }
const nav: Item[] = [
  { key: 'about', label: 'About Us', href: '/about' },
  {
    key: 'regions', label: 'Fishing regions', href: '/fishing-regions',
    dropdown: [
      { label: 'Dubai Marina & Coast', href: '/fishing-regions#dubai-marina' },
      { label: 'Persian Gulf Deep Sea', href: '/fishing-regions#persian-gulf' },
      { label: 'Palm Jumeirah Waters', href: '/fishing-regions#palm-jumeirah' },
      { label: 'Musandam Peninsula', href: '/fishing-regions#musandam' },
      { label: 'All fishing regions', href: '/fishing-regions' },
    ],
  },
  { key: 'yachts', label: 'Yacht Rental', href: '/yacht-rental' },
  {
    key: 'excursions', label: 'Excursions Dubai', href: '/excursions',
    dropdown: [
      { label: 'Sightseeing Cruises', href: '/excursions#sightseeing' },
      { label: 'Yacht Fishing', href: '/excursions#fishing' },
      { label: 'Water Sports', href: '/excursions#water-sports' },
      { label: 'Yacht Party', href: '/excursions#yacht-party' },
      { label: 'Romantic Cruise', href: '/excursions#romantic' },
      { label: 'Corporate Cruise', href: '/excursions#corporate' },
    ],
  },
  { key: 'contacts', label: 'Contacts', href: '/contacts' },
];

const linkBase = 'relative flex items-center gap-[5px] no-underline transition-colors duration-150 hover:text-brand';
const dropdownPanel =
  "absolute top-full left-[-14px] min-w-[230px] bg-white border border-line-soft rounded-xl shadow-[0_18px_44px_rgba(20,50,75,.16)] p-2 z-[60] opacity-0 invisible translate-y-2 transition-[opacity,transform] duration-200 group-hover:opacity-100 group-hover:visible group-hover:translate-y-[6px] before:content-[''] before:absolute before:inset-x-0 before:-top-3 before:h-3.5";
const dropdownLink =
  'block px-[13px] py-[9px] rounded-lg text-[14px] font-semibold text-[#42525f] no-underline transition-colors duration-150 hover:bg-[#f1f6fb] hover:text-brand';
---

<header class="sticky top-0 z-50 bg-white border-b border-line-soft">
  <div class="container flex items-center justify-between gap-6 h-[72px]">
    <a href="/" class="flex items-center" aria-label="Emirates Fishing Tour — home">
      <Image src={logoBlue} alt="Emirates Fishing Tour" class="h-[38px] w-auto block" />
    </a>

    <nav class="flex max-[980px]:hidden items-center gap-[26px] font-semibold text-[15px] text-[#42525f]" aria-label="Primary">
      {nav.map((item) => item.dropdown ? (
        <span class="relative group">
          <a class={`${linkBase} ${active === item.key ? 'text-brand font-bold' : 'text-[#42525f]'}`} href={item.href}>
            {item.label} <span class="text-[9px] text-[#a9b6c0]">&#9660;</span>
            {active === item.key && <span class="absolute left-0 right-0 -bottom-[26px] h-0.5 bg-brand rounded-sm"></span>}
          </a>
          <span class={dropdownPanel}>
            {item.dropdown.map((d) => <a class={dropdownLink} href={d.href}>{d.label}</a>)}
          </span>
        </span>
      ) : (
        <a class={`${linkBase} ${active === item.key ? 'text-brand font-bold' : 'text-[#42525f]'}`} href={item.href}>
          {item.label}
          {active === item.key && <span class="absolute left-0 right-0 -bottom-[26px] h-0.5 bg-brand rounded-sm"></span>}
        </a>
      ))}
      <span class="w-px h-5 bg-[#e6ebef]"></span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#8794a0" stroke-width="1.6" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1.1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"></path></svg>
      <span class="flex items-center gap-[5px] text-[#42525f] font-semibold cursor-pointer">EN <span class="text-[9px] text-[#a9b6c0]">&#9660;</span></span>
    </nav>

    <label for="navtoggle" class="hidden max-[980px]:flex cursor-pointer w-[42px] h-[42px] border border-[#e6ebef] rounded-[10px] items-center justify-center" aria-label="Open menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#27384a" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"></path></svg>
    </label>
  </div>

  <input type="checkbox" id="navtoggle" class="peer hidden" />
  <div class="hidden max-[980px]:peer-checked:flex flex-col px-7 pt-[6px] pb-[18px] bg-white border-t border-line">
    {nav.map((item) => (
      <>
        <a class={`py-[13px] px-1 border-b border-line font-bold text-base no-underline ${active === item.key ? 'text-brand' : 'text-[#27384a]'}`} href={item.href}>{item.label}</a>
        {item.dropdown && item.dropdown.slice(0, -1).map((d) => (
          <a class="py-[9px] pr-1 pl-[18px] border-b border-[#f4f7fa] text-[#6b7a88] font-semibold text-[14px] no-underline" href={d.href}>{d.label}</a>
        ))}
      </>
    ))}
  </div>
</header>

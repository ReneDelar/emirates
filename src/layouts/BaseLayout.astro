---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { NavKey } from '../components/Header.astro';

interface Props {
  title: string;
  description: string;
  active?: NavKey;
}
const { title, description, active } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <!-- Set before paint so the to-be-animated elements start hidden (no flash).
         Skipped when JS is off or the user prefers reduced motion → content stays visible. -->
    <script is:inline>
      if (!window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('anim');
      }
    </script>
  </head>
  <body>
    <Header active={active} />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      try {
      gsap.registerPlugin(ScrollTrigger);

      const mm = gsap.matchMedia();

      // Full animation only when the user is fine with motion.
      mm.add('(prefers-reduced-motion: no-preference)', () => {
        // Expand a content wrapper into the elements we actually animate:
        // grid containers become their items (cards stagger one-by-one), everything
        // else stays as-is. Background images / overlays live outside these wrappers,
        // so they're never touched.
        const collect = (root) => {
          const items = [];
          for (const child of Array.from(root.children)) {
            if (child.classList.contains('grid')) items.push(...child.children);
            else items.push(child);
          }
          return items;
        };

        // Hero — plays immediately on load (it's above the fold).
        const hero = document.querySelector('.hero');
        if (hero) {
          const inner = hero.querySelector('.hero__inner');
          if (inner) {
            gsap.fromTo(
              inner.children,
              { y: 42, autoAlpha: 0 },
              { y: 0, autoAlpha: 1, duration: 0.9, ease: 'power3.out', stagger: 0.12, delay: 0.08 }
            );
          }
        }

        // Every other section — reveals as it scrolls into view, items staggered.
        gsap.utils.toArray('[data-reveal]').forEach((sec) => {
          if (sec.classList.contains('hero')) return;
          const root = sec.querySelector('.cta__inner') || sec.querySelector('.container') || sec;
          const items = collect(root);
          if (!items.length) return;
          gsap.fromTo(
            items,
            { y: 40, autoAlpha: 0 },
            {
              y: 0,
              autoAlpha: 1,
              duration: 0.7,
              ease: 'power3.out',
              stagger: { each: 0.08, amount: Math.min(items.length * 0.08, 0.55) },
              scrollTrigger: { trigger: sec, start: 'top 82%', once: true },
            }
          );
        });

        // Recompute trigger positions once images/fonts settle the layout.
        window.addEventListener('load', () => ScrollTrigger.refresh());
      });
      } catch (e) {
        // Safety net: never leave content hidden if animation setup fails.
        document.documentElement.classList.remove('anim');
        console.error('[anim] setup failed, content revealed', e);
      }
    </script>
  </body>
</html>
